.userinfo {
  align-items: center;
  display: flex;
  flex-direction: column;
}

.userinfo-avatar {
  border-radius: 50%;
  height: 128rpx;
  margin: 20rpx;
  width: 128rpx;
}

.userinfo-nickname {
  color: #aaa;
}

.usermotto {
  margin-top: 200px;
}

.heart-container {
  width: 100%;
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;

}

.heart {
  height: 140rpx;
  width: 140rpx;
  background: #f20044;
  transform: rotate(-45deg);
  box-shadow: -20rpx -20rpx 180rpx #f20044;
  position: relative;
}

.heart:before {
  content: "";
  position: absolute;
  height: 140rpx;
  width: 140rpx;
  background: #f20044;
  top: -50%;
  border-radius: 70rpx;
}

.heart:after {
  content: "";
  position: absolute;
  height: 140rpx;
  width: 140rpx;
  background: #f20044;
  right: -50%;
  border-radius: 70rpx;
  transition: all 0.3s;
}

/* 等级 0 - 静态 */
@keyframes heart-animation-0 {
  0% {
    transform: rotate(-45deg) scale(1);
  }

  100% {
    transform: rotate(-45deg) scale(1);
  }
}

/* 等级 1 - 慢速跳动 */
@keyframes heart-animation-1 {
  0% {
    transform: rotate(-45deg) scale(1.07);
    filter: blur(0px);
  }

  80% {
    transform: rotate(-45deg) scale(1);
    filter: blur(1px);
  }

  100% {
    transform: rotate(-45deg) scale(0.8);
    filter: blur(2px);
  }
}

/* 等级 2 - 中速跳动 */
@keyframes heart-animation-2 {
  0% {
    transform: rotate(-45deg) scale(1.07);
    filter: blur(0px);
  }

  80% {
    transform: rotate(-45deg) scale(1);
    filter: blur(1px);
  }

  100% {
    transform: rotate(-45deg) scale(0.8);
    filter: blur(2px);
  }
}

/* 等级 3 - 快速跳动 */
@keyframes heart-animation-3 {
  0% {
    transform: rotate(-45deg) scale(1.07);
    filter: blur(0px);
  }

  80% {
    transform: rotate(-45deg) scale(1);
    filter: blur(1px);
  }

  100% {
    transform: rotate(-45deg) scale(0.8);
    filter: blur(2px);
  }
}

.circle {
  border: 0 solid #fff;
  border-radius: 500px;
  height: 30px;
  width: 30px;
}

.adContainer {
  width: 100%;
}