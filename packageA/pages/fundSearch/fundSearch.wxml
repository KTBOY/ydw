<!-- packageA/pages/fundSearch/fundSearch.wxml -->
<view class="fund-search-page">
  <view class="search-row">
    <view class="search-input-wrap">
      <icon class="input-icon" type="search" size="14" color="#9ea5b1" />
      <input
        class="search-input"
        placeholder="输入基金名称或代码"
        confirm-type="search"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <icon wx:if="{{searchValue}}" class="clear-icon" type="clear" size="16" color="#bcc2cb" bindtap="onClearInput" />
    </view>
    <view class="search-btn" bindtap="onSearchSubmit">搜索</view>
  </view>

  <view class="result-list" wx:if="{{searchValue}}">
    <view class="state-text" wx:if="{{loading}}">基金列表加载中...</view>

    <block wx:for="{{renderList}}" wx:key="code">
      <view class="result-item" bindtap="onTapResultItem" data-name="{{item.name}}" data-code="{{item.code}}">
        <icon class="result-icon" type="search" size="13" color="#c2c8d1" />
        <text class="result-name">{{item.name}}</text>
        <text class="result-code">{{item.code}}</text>
      </view>
    </block>

    <view class="state-text" wx:if="{{!loading && !renderList.length}}">暂无匹配基金</view>
    <view class="state-text state-warn" wx:if="{{errorMsg}}">{{errorMsg}}</view>
  </view>

  <view class="history-card" wx:if="{{!searchValue && searchHistory.length}}">
    <view class="history-header">
      <text class="history-title">搜索历史</text>
      <text class="history-clear" bindtap="onClearHistory">清空</text>
    </view>
    <view class="history-list">
      <view class="history-item" wx:for="{{searchHistory}}" wx:key="*this" bindtap="onTapHistoryWord" data-word="{{item}}">
        {{item}}
      </view>
    </view>
  </view>
</view>
