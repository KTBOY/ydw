/* packageA/pages/fundSearch/fundSearch.wxss */
page {
  background: #f3f5f8;
}

.fund-search-page {
  padding: 24rpx;
  box-sizing: border-box;
}

.search-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  background: #ffffff;
  border: 2rpx solid #d8e3f6;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  box-sizing: border-box;
}

.search-prefix {
  font-size: 24rpx;
  color: #9ba8bf;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #2e3540;
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  margin-left: 12rpx;
  border-radius: 36rpx;
  background: linear-gradient(120deg, #5b89ff 0%, #3c6df2 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-top: 18rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #273240;
}

.clear-btn {
  font-size: 24rpx;
  color: #98a1af;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.tag-item {
  max-width: 320rpx;
  padding: 10rpx 20rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #4f5a6e;
  background: #f2f5fb;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-hot {
  color: #ff623c;
  background: #fff1ec;
}

.rank-card {
  margin-top: 18rpx;
  border-radius: 24rpx;
  padding: 22rpx;
  background: linear-gradient(180deg, #fff7ef 0%, #ffffff 100%);
  border: 1rpx solid #f6dac6;
}

.rank-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.rank-title-wrap {
  display: flex;
  align-items: baseline;
}

.rank-title {
  color: #ff592f;
  font-size: 34rpx;
  font-weight: 700;
}

.rank-subtitle {
  margin-left: 10rpx;
  color: #f08f6a;
  font-size: 22rpx;
}

.rank-date {
  color: #9ea7b5;
  font-size: 22rpx;
}

.rank-column-head {
  margin-top: 18rpx;
  padding: 0 0 10rpx 54rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f3e4d8;
}

.col-fund {
  flex: 1;
  color: #a08a79;
  font-size: 22rpx;
}

.col-net,
.col-change {
  width: 150rpx;
  text-align: right;
  color: #a08a79;
  font-size: 22rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f7ebe2;
}

.rank-item:last-child {
  border-bottom: none;
}

.item-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.rank-index {
  width: 38rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
}

.rank-index.top-1 {
  color: #ff9500;
}

.rank-index.top-2 {
  color: #ff8c48;
}

.rank-index.top-3 {
  color: #f7b500;
}

.rank-index.normal {
  color: #a9afba;
}

.item-info {
  min-width: 0;
  margin-left: 16rpx;
}

.item-name {
  display: block;
  color: #29323d;
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: block;
  margin-top: 6rpx;
  color: #9ca5b5;
  font-size: 22rpx;
}

.item-right {
  width: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.item-net {
  color: #465264;
  font-size: 26rpx;
}

.item-change {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.item-change.up {
  color: #ef4f42;
}

.item-change.down {
  color: #1fb889;
}

.item-change.flat {
  color: #8e9aab;
}

.state-text {
  text-align: center;
  color: #98a2b3;
  font-size: 24rpx;
  padding: 20rpx 0 10rpx;
}

.state-warn {
  color: #c58b71;
}
