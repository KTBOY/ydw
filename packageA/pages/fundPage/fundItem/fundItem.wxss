page {
  background: #eceef3;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.glass-card {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: #eceef3;
  border: 1rpx solid #e2e5ec;
  box-shadow:
    12rpx 12rpx 24rpx #d7dbe3,
    -10rpx -10rpx 22rpx #ffffff;
}

.header {
  padding: 28rpx 24rpx 24rpx;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header .name {
  max-width: 70%;
  font-size: 38rpx;
  font-weight: 700;
  color: #434b5d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header .code {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #7b8394;
  background: #f2f4f8;
  border: 1rpx solid #dee2ea;
  box-shadow:
    inset 2rpx 2rpx 6rpx #d8dce4,
    inset -2rpx -2rpx 6rpx #ffffff;
}

.rate {
  margin-top: 18rpx;
  font-size: 68rpx;
  font-weight: 700;
  line-height: 1;
}

.up {
  color: #ff6e92;
}

.down {
  color: #22be87;
}

.time {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8a92a3;
}

.info-card {
  padding: 22rpx;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #4c5568;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.info-item {
  width: calc(50% - 10rpx);
  margin-bottom: 16rpx;
  padding: 18rpx 14rpx;
  border-radius: 24rpx;
  background: #ebedf2;
  border: 1rpx solid #dfe3ea;
  box-shadow:
    8rpx 8rpx 16rpx #d5d9e1,
    -8rpx -8rpx 16rpx #ffffff;
  box-sizing: border-box;
}

.info-item .label {
  display: block;
  font-size: 24rpx;
  color: #8d95a5;
}

.info-item .value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #464f62;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}
