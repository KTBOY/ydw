page {
  background: #eceef3;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.glass-card {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: #eceef3;
  border: 1rpx solid #e2e5ec;
  box-shadow:
    12rpx 12rpx 24rpx #d7dbe3,
    -10rpx -10rpx 22rpx #ffffff;
}

.header {
  padding: 28rpx 24rpx 24rpx;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header .name {
  max-width: 70%;
  font-size: 38rpx;
  font-weight: 700;
  color: #434b5d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header .code {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #7b8394;
  background: #f2f4f8;
  border: 1rpx solid #dee2ea;
  box-shadow:
    inset 2rpx 2rpx 6rpx #d8dce4,
    inset -2rpx -2rpx 6rpx #ffffff;
}

.rate {
  margin-top: 18rpx;
  font-size: 68rpx;
  font-weight: 700;
  line-height: 1;
}

.up {
  color: #ff6e92;
}

.down {
  color: #22be87;
}

.time {
  font-size: 24rpx;
  color: #8a92a3;
}

.meta-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.refresh-btn {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 132rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #eef1f6;
  border: 1rpx solid #dfe3ea;
  box-shadow:
    inset 2rpx 2rpx 6rpx #ffffff,
    inset -2rpx -2rpx 6rpx #d7dbe3;
  box-sizing: border-box;
}

.refresh-text {
  font-size: 22rpx;
  color: #7b8394;
  line-height: 1;
}

.refresh-mark {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffffff, #d9dde5);
  box-shadow:
    2rpx 2rpx 6rpx #d0d5de,
    -2rpx -2rpx 6rpx #ffffff;
}

.refresh-spinner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 3rpx solid #c8ced9;
  border-top-color: #7b8394;
  animation: rotate 0.8s linear infinite;
  box-sizing: border-box;
}

.is-refreshing {
  opacity: 0.88;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.info-card {
  padding: 22rpx;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #4c5568;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.info-item {
  width: calc(50% - 10rpx);
  margin-bottom: 16rpx;
  padding: 18rpx 14rpx;
  border-radius: 24rpx;
  background: #ebedf2;
  border: 1rpx solid #dfe3ea;
  box-shadow:
    8rpx 8rpx 16rpx #d5d9e1,
    -8rpx -8rpx 16rpx #ffffff;
  box-sizing: border-box;
}

.info-item .label {
  display: block;
  font-size: 24rpx;
  color: #8d95a5;
}

.info-item .value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #464f62;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.wrap {
  border: 1px solid #dcdcdc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-around;
  padding: 8px 0;
  border-radius: 22px;
  box-shadow:
    0px 5px 5px -3px rgba(0, 0, 0, 0.1),
    0px 8px 10px 1px rgba(0, 0, 0, 0.06),
    0px 3px 14px 2px rgba(0, 0, 0, 0.05);
  background: rgba(255, 255, 255, 1);
  width: 44px;
  height: 156px;
  box-sizing: border-box;
}

.item {
  width: 100%;
  height: 44px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  font-size: 12px;
  color: rgba(0, 0, 0, 0.9);
  cursor: pointer;
}

.item:not(:last-child) {
  margin-bottom: 4px;
}

.text {
  height: 20px;
  line-height: 20px;
}

.symbol {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16px 0 0 16px;
  background: #fff;

  border: 1px solid #dcdcdc;
  border-right: 0;
  box-shadow:
    0px 5px 5px -3px #0000001a,
    0px 8px 10px 1px #0000000f,
    0px 3px 14px 2px #0000000d;
}
