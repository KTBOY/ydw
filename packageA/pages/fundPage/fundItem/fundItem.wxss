page {
  /* min-height: 100vh;
  color: #dbe8ff;
 */
  /* background: linear-gradient(180deg, #020731 0%, #010522 65%, #000418 100%); */
  background: linear-gradient(145deg, #070e2c 0%, #02071d 55%, #000413 100%);
}

.page {
  /* min-height: 100vh; */
  padding: 24rpx 24rpx 36rpx;
  box-sizing: border-box;
  /* background-image:
    radial-gradient(circle at 20% 0%, rgba(47, 88, 255, 0.25), transparent 36%),
    radial-gradient(circle at 100% 100%, rgba(22, 180, 255, 0.14), transparent 40%); */

}

.glass-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  background: linear-gradient(160deg, rgba(20, 36, 84, 0.6), rgba(10, 21, 54, 0.5));
  border: 1rpx solid rgba(68, 116, 255, 0.3);
  box-shadow:
    inset 0 1rpx 0 rgba(126, 170, 255, 0.28),
    0 10rpx 26rpx rgba(0, 7, 40, 0.45);
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header .name {
  max-width: 70%;
  font-size: 38rpx;
  font-weight: 700;
  color: #ecf3ff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header .code {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #9eb7ec;
  background: rgba(83, 120, 245, 0.22);
  border: 1rpx solid rgba(84, 141, 255, 0.5);
}

.rate {
  margin-top: 20rpx;
  font-size: 68rpx;
  font-weight: 700;
  line-height: 1;
}

.up {
  color: #ff6288;
}

.down {
  color: #00e6a6;
}

.time {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #88a6e3;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #d9e7ff;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.info-item {
  width: 48.5%;
  margin-bottom: 14rpx;
  padding: 16rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(8, 27, 90, 0.72);
  border: 1rpx solid rgba(75, 122, 255, 0.24);
  box-sizing: border-box;
}

.info-item .label {
  display: block;
  font-size: 24rpx;
  color: #85a0d8;
}

.info-item .value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #edf3ff;
  font-weight: 600;
  word-break: break-all;
}