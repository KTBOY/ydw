/* packageA/pages/fundSearch/fundSearch.wxss */
page {
  background: #f5f6fa;
}

.fund-card {


  border-radius: 28rpx;
  background: #eceef3;
  border: 1rpx solid #e2e5ec;
  box-shadow:
    12rpx 12rpx 24rpx #d7dbe3,
    -10rpx -10rpx 22rpx #ffffff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 18rpx 18rpx 16rpx;
  box-sizing: border-box;
}

.my-fund {
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #dde1e9;
  background: #eceef3;
  box-shadow:
    inset 3rpx 3rpx 10rpx #d8dce5,
    inset -3rpx -3rpx 10rpx #ffffff;
  display: flex;
}

.my-fund-header {
  min-height: 72rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #dfe3eb;
  flex: 1;
}

.my-fund-title-wrap {
  display: flex;
  align-items: center;
  width: 100%;
}

.my-fund-star {
  color: #ffbc4a;
  font-size: 26rpx;
  margin-right: 10rpx;
}

.my-fund-title {
  color: #4e5668;
  font-size: 34rpx;
  font-weight: 700;
}

.my-fund-count {
  color: #8f96a6;
  font-size: 24rpx;
}

.fund-search-page {
  padding: 136rpx 0 32rpx;
  box-sizing: border-box;
}

.search-bar-shell {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 18rpx 18rpx 16rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f8f9fc 0%, #f2f4f8 100%);
}

.search-row {
  display: flex;
  align-items: center;
  padding: 12rpx;
  border-radius: 30rpx;
  background: #eef1f7;
  box-shadow: inset 0 2rpx 8rpx rgba(255, 255, 255, 0.95),
    inset 0 -4rpx 10rpx rgba(209, 214, 225, 0.4);
}

.search-input-wrap {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fdfdfe 0%, #eef1f6 100%);
  border: 1rpx solid rgba(228, 232, 240, 0.9);
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.95),
    inset 0 -3rpx 8rpx rgba(211, 217, 227, 0.5);
}

.input-icon {
  flex-shrink: 0;
  opacity: 0.85;
}

.search-input {
  flex: 1;
  height: 72rpx;
  margin: 0 14rpx;
  font-size: 28rpx;
  color: #4e5664;
}

.search-placeholder {
  color: #b7bcc6;
}

.clear-icon {
  flex-shrink: 0;
}

.search-btn {
  margin-left: 16rpx;
  padding: 0 10rpx;
  color: #9aa2af;
  font-size: 26rpx;
  line-height: 1;
  width: 80rpx;
  text-align: center;
  display: flex;
  align-items: center;
}

.result-list {
  margin-top: 14rpx;
  background: #f5f6fa;
}

.result-item {
  display: flex;
  align-items: center;
  min-height: 86rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #f5f6fa;
  border-bottom: 1rpx solid #e8ebf0;
}

.result-icon {
  flex-shrink: 0;
  margin-right: 14rpx;
}

.result-name {
  flex: 1;
  min-width: 0;
  font-size: 33rpx;
  color: #2e3033;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-code {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #9ea5b0;
}

.history-card {
  margin: 0 18rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(29, 43, 76, 0.05);
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-title {
  font-size: 28rpx;
  color: #222936;
  font-weight: 600;
}

.history-clear {
  font-size: 24rpx;
  color: #9ea6b2;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.history-item {
  max-width: 100%;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 8rpx;
  background: #f3f6fb;
  color: #49505d;
  font-size: 24rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.state-text {
  text-align: center;
  color: #9ea5b0;
  font-size: 24rpx;
  padding: 26rpx 16rpx;
}

.state-warn {
  color: #cf7f59;
}