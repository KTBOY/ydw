@import '../../assets/icon/icon.wxss';
@import '../../assets/icon/svg.wxss';
@import '../../assets/font/stylesheet.wxss';

page {
  height: 100vh;
  width: 100vw;
  box-sizing: border-box;
  font-size: 28rpx;
  position: relative;
  color: #212121;
  overflow-x: hidden;
  background: #fcf1ed;
}

.container_index {
  width: 100%;
  min-height: 100%;
  height: fit-content;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  background: linear-gradient(180deg, #735afd 0%, #fef3ed 100%);
  padding: 220rpx 0 40rpx;
}

.container_index .main_top {
  position: relative;
  margin-bottom: 4rpx;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
}

.container_index .main_top image {
  width: 100%;
  height: 100%;
}

.container_index .main_body {
  background-image: linear-gradient(to top, #dfe9f3 0%, white 30%);
  border-radius: 56rpx 56rpx 28rpx 28rpx;
  padding: 38rpx 28rpx 30rpx;
  position: relative;
  margin: 0 20rpx;
  width: calc(100vw - 40rpx);
  z-index: 10;
  box-sizing: border-box;
  box-shadow: 1px 2px 4px 0 rgba(0, 58, 152, 0.1), 0 0 3px 0 rgba(0, 0, 0, 0.1);
}

.container_index .main_body .header {
  display: flex;
  align-items: center;
  position: relative;
  margin: -12rpx 0;
  justify-content: space-between;
}

.container_index .main_body .header .header_left {
  display: flex;
  align-items: center;
}

.container_index .main_body .header .header_left .img {
  margin-right: 12rpx;
}

.container_index .main_body .header .header_left .title {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 82rpx;
}

.container_index .main_body .header .header_left .title .fir {
  font-weight: bold;
  color: #141f48;
  line-height: 36rpx;
  font-size: 36rpx;
}

.container_index .main_body .header .header_left .title .sub {
  line-height: 24rpx;
  font-size: 28rpx;
  color: #999;
}

.container_index .main_body .header .header_right {
  margin-right: 28rpx;
  height: 72rpx;
  width: 72rpx;
  background-size: contain;
}

.container_index .main_body .navtab {
  position: relative;
  padding: 24rpx 10rpx 42rpx;
  display: flex;
  margin-bottom: 16rpx;
  justify-content: space-between;
  border-bottom: 2rpx dashed transparent;
  background: linear-gradient(white, white) padding-box, repeating-linear-gradient(-45deg, #eae9ef 0, #eae9ef 0.25em, white 0, white 0.75em);
}

.container_index .main_body .navtab .navtab_li {
  flex: 1;
  font-size: 28rpx;
  text-align: center;
  padding: 6rpx 0rpx;
  border-radius: 64rpx;
  background: #efecff;
  color: #735afd;
  word-break: keep-all;
}

.container_index .main_body .navtab .navtab_li+.navtab_li {
  margin-left: 20rpx;
}

.container_index .main_body .navtab .navtab_li.active {
  color: white;
  font-weight: bold;
  background: linear-gradient(90deg, #735afd 0%, #b63af3 100%);
}

.container_index .main_body .navtab .star_date {
  position: absolute;
  right: -28rpx;
  bottom: -20rpx;
}

.container_index .main_body .navtab .star_date view {
  background: linear-gradient(90deg, #735afd 0%, #b63af3 100%);
  padding: 4rpx 20rpx;
  border-radius: 80rpx 0rpx 0rpx 80rpx;
  color: white;
  font-size: 24rpx;
  display: inline-block;
}

.container_index .main_body .star_content {
  display: flex;
  flex-wrap: wrap;
  padding: 30rpx 10rpx;
  border-bottom: 2rpx dashed #eae9ef;
  position: relative;
}

.container_index .main_body .star_content .star_desc {
  color: rgba(113, 88, 253, 0.9);
  font-size: 28rpx;
  left: 0;
  width: 100%;
  text-align: center;
  transition: 0.2s;
  margin-bottom: 35rpx;

}

.container_index .main_body .star_content .star_desc text {
  background: white;
}

.container_index .main_body .star_content .star_content_li {
  margin-bottom: 18rpx;
  width: 50%;
  font-size: 28rpx;
  color: #735afd;
  display: flex;
  flex-shrink: 0;
}

.container_index .main_body .star_content .star_content_li .li_label {
  color: #181f64;
  margin-right: 12rpx;
}

.container_index .main_body .star_content .star_content_li .li_val {
  display: flex;
  align-items: center;
}

.container_index .main_body .star_content .star_content_li .li_val .icon-pingfen {
  font-size: 32rpx;
  color: #ffeeb9;
  margin-left: 2rpx;
  transition: 0.2s;
}

.container_index .main_body .star_content .star_content_li .li_val .icon-pingfen.yellow {
  color: #fdd246;
}

.container_index .main_body .star_content .share_btn {
  position: fixed;
  width: 160rpx;
  height: 160rpx;
  right: -20rpx;
  bottom: 18%;
  padding: 0;
  margin: 0;
  background: none;
  z-index: 9;
}

.container_index .main_body .star_textbox_ul {
  position: relative;
  transition: all 0.5s ease-in;
  overflow: hidden;
}

.container_index .main_body .star_textbox {
  padding: 30rpx 10rpx;
  font-size: 28rpx;
  line-height: 1.7;
  opacity: 1;
}

.container_index .main_body .star_textbox:first-child {
  background: #f8f8ff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.container_index .main_body .star_textbox:first-child .star_textbox_li view {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f5;
  display: flex;
  justify-content: space-between;
}

.container_index .main_body .star_textbox:first-child .star_textbox_li view:last-child {
  border-bottom: none;
}

.container_index .main_body .star_textbox .star_textbox_title {
  display: flex;
  color: rgba(113, 88, 253, 0.9);
  font-size: 32rpx;
  align-items: center;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.container_index .main_body .star_textbox .star_textbox_title .icon {
  margin-right: 10rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: rgba(113, 88, 253, 0.9);
}

.container_index .main_body .star_textbox+.star_textbox {
  border-top: 2rpx dashed #eae9ef;
}