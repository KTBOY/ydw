@import '../../assets/style/dialog.wxss';

.tip_modal_dialog {
  vertical-align: top;
  margin-top: 26vh;
  margin-left: 0rpx;
  margin-right: 0rpx;
  width: auto;
}

.tip_modal_dialog .dialog_content {
  padding: 36rpx 32rpx 36rpx;
  border-radius: 0 0 28rpx 28rpx;
  background-image: linear-gradient(to top, #dfe9f3 0%, white 30%);
  position: relative;
}

.tip_modal_dialog .dialog_content .img_hd {
  position: absolute;
  top: -76rpx;
  left: 0;
  width: 100%;
  height: 80rpx;
}

.tip_modal_dialog .dialog_content .img_hd image {
  width: 100%;
  height: 100%;
}

.tip_modal_dialog .dialog_content .nav {
  display: flex;
  flex-wrap: wrap;
}

.tip_modal_dialog .dialog_content .nav .nav-li {
  font-size: 24rpx;
  word-break: keep-all;
  width: 33%;
  margin-bottom: 50rpx;
  padding: 10rpx 0;
  color: rgba(0, 0, 0, 0.8);
  position: relative;
  -webkit-text-stroke-width: 2rpx;
  -webkit-text-stroke-color: rgba(0, 0, 0, 0.3);
}

.tip_modal_dialog .dialog_content .nav .nav-li .title {
  font-size: 48rpx;
  font-weight: bold;
}

.tip_modal_dialog .dialog_content .nav .nav-li .date {
  margin-top: 4rpx;
}

.tip_modal_dialog .dialog_content .nav .nav-li.active {
  color: #735afd;
  -webkit-text-stroke-width: 2rpx;
  -webkit-text-stroke-color: rgba(115, 90, 253, 0.3);
}

.tip_modal_dialog .dialog_content .nav .nav-li.active::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -2rpx;
  height: 6rpx;
  background: #735afd;
  opacity: 0.8;
  margin: auto;
  width: 80rpx;
  border-radius: 8rpx;
}

.tip_modal_dialog .foot_button {
  padding: 30rpx 0 0;
  font-weight: bold;
  display: flex;
  justify-content: center;
}