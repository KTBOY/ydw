  background-color: #040922;
} */

.fund-card {
  /* margin: 24rpx; */
  /* border-radius: 28rpx; */
  padding: 28rpx;

  background: linear-gradient(145deg, #070e2c 0%, #02071d 55%, #000413 100%);
  border: 1rpx solid rgba(116, 91, 255, 0.45);
  /* box-shadow: 0 18rpx 40rpx rgba(4, 9, 34, 0.5), inset 0 0 0 1rpx rgba(255, 255, 255, 0.04); */
}

.fund-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.example-search {}


.search-info {
  width: 98%;

  padding: 15rpx 5rpx;
  border-radius: 10rpx;
  border: 2rpx solid var(--td-search-bg-color, var(--td-bg-color-secondarycontainer, var(--td-gray-color-1, #f3f3f3)));
  background: var(--td-search-bg-color, var(--td-bg-color-secondarycontainer, var(--td-gray-color-1, #f3f3f3)));
}

.title-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.title-icon {
  width: 46rpx;
  height: 46rpx;
  border-radius: 14rpx;
  background: linear-gradient(120deg, #6d57ff 0%, #7f41ff 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.title-text {
  color: #eef2ff;
  font-size: 34rpx;
  font-weight: 700;
}

.live-tag {
  height: 46rpx;
  border-radius: 24rpx;
  padding: 0 18rpx;
  background: rgba(9, 192, 142, 0.14);
  border: 1rpx solid rgba(9, 192, 142, 0.35);
  display: flex;
  align-items: center;
}

.live-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00d58a;
  box-shadow: 0 0 10rpx #00d58a;
  margin-right: 10rpx;
}

.live-text {
  color: #8fffd1;
  font-size: 22rpx;
  font-weight: 600;
}

.fund-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.fund-item {
  width: calc(50% - 50rpx);
  padding: 18rpx;
  margin-bottom: 16rpx;
  border-radius: 18rpx;
  background: linear-gradient(160deg, rgba(20, 36, 84, 0.6), rgba(10, 21, 54, 0.5));
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.fund-name {
  display: block;
  color: #c6d2ff;
  font-size: 24rpx;
  line-height: 1.3;
}

.fund-code {
  display: block;
  color: #7280b6;
  font-size: 20rpx;
  margin-top: 4rpx;
}

.fund-current {
  display: block;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  margin-top: 10rpx;
}

.fund-change-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.change,
.rate {
  font-size: 22rpx;
  font-weight: 600;
}

.up {
  color: #ff6f8f;
}

.down {
  color: #30dd97;
}

.flat {
  color: #9fb2ff;
}

.bar-board {
  margin-top: 22rpx;
  padding: 14rpx 12rpx;
  border-radius: 18rpx;
  background: linear-gradient(160deg, rgba(19, 32, 74, 0.75), rgba(10, 19, 52, 0.68));
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  min-height: 110rpx;
}

.bar-item {
  width: 44rpx;
  height: 96rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.bar {
  width: 20rpx;
  border-radius: 8rpx;
  background: linear-gradient(180deg, #6a6eff 0%, #4750d3 100%);
}

.bar.up {
  background: linear-gradient(180deg, #ff8da6 0%, #ff5b7d 100%);
}

.bar.down {
  background: linear-gradient(180deg, #46ecab 0%, #20bf7f 100%);
}

.footer-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.footer-label {
  color: #9eb0ea;
  font-size: 24rpx;
}

.footer-btn {
  padding: 0 20rpx;
  height: 50rpx;
  border-radius: 24rpx;
  background: linear-gradient(130deg, #6d57ff 0%, #8546ff 100%);
  display: flex;
  align-items: center;
}

.footer-btn-text {
  color: #f8f4ff;
  font-size: 22rpx;
  font-weight: 600;
}

.footer-btn-arrow {
  color: #f8f4ff;
  font-size: 28rpx;
  margin-left: 8rpx;
  transform: translateY(-1rpx);
}

.my-fund {
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(112, 141, 255, 0.24);
  background: linear-gradient(165deg, rgba(14, 26, 61, 0.95), rgba(5, 13, 37, 0.95));
}

.my-fund-header {
  height: 72rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.my-fund-title-wrap {
  display: flex;
  align-items: center;
}

.my-fund-star {
  color: #ffcc40;
  font-size: 26rpx;
  margin-right: 12rpx;
}

.my-fund-title {
  color: #f1f4ff;
  font-size: 34rpx;
  font-weight: 700;
}

.my-fund-count {
  color: #6278a5;
  font-size: 24rpx;
}

.my-fund-item {
  padding: 22rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.my-fund-item+.my-fund-item {
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.my-fund-left {
  min-width: 0;
  padding-right: 20rpx;
}

.my-fund-name {
  display: block;
  color: #f2f5ff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.my-fund-code {
  display: block;
  color: #ffd451;
  font-size: 30rpx;
  margin-top: 8rpx;
}

.my-fund-right {
  display: flex;
  align-items: flex-end;
  flex-direction: column;
}

.my-fund-change-wrap {
  display: flex;
  align-items: center;
}

.my-fund-change {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1;
}

.my-fund-remove {
  color: #6982b1;
  font-size: 34rpx;
  margin-left: 16rpx;
  line-height: 1;
  transform: translateY(-2rpx);
}

.my-fund-time {
  color: #6d81aa;
  font-size: 24rpx;
  margin-top: 12rpx;
}