::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

.tab-box {}

.left-scroll {
  width: 750rpx;
  /* 固定宽度 */
  background-color: #ffffff;
  height: 50px;





}

.two-clr {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;

}

.left-list {
  display: flex;
  /* justify-content: space-around; */
  align-items: center;
  padding: 5rpx 10rpx;
}

.nav-item {
  white-space: nowrap;
  margin: 0 10rpx;


}

.active {
  font-weight: bold;
}

.item-active {
  width: 80rpx;
  border-radius: 10rpx;
  height: 5rpx;
  background-color: var(--td-brand-color);
  color: #fff;
  transition: all 0.5s;
  margin-bottom: 15rpx;
}


.grid-scroll {
  background-color: #fff;
}

.grid-list {
  display: flex;
  background-color: #fff;
  margin: 0 10rpx;
  padding-bottom: 15rpx;
  padding-top: 5rpx;
}

.grid-item {
  height: 50rpx;
  padding: 10rpx 26rpx;
  margin: 0 5rpx;
  white-space: nowrap;
  border-radius: 10rpx;
  text-align: center;

}

.grid-active {
  background-color: var(--td-brand-color);
  color: #fff;
}