.page {
  background: #F6E8EB;
  padding: 20rpx;
}

.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.title {
  font-size: 34rpx;
  color: #333;
}

.search {
  width: 36rpx;
  height: 36rpx;
}

.tabs {
  white-space: nowrap;
  margin-bottom: 30rpx;
}

.tab {
  display: inline-block;
  padding: 0 28rpx;
  margin-right: 10rpx;
}

.active {
  background: #E9DFFF;
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  color: #333;
}

.fortune {
  background: #E9DFFF;
  padding: 32rpx;
  border-radius: 26rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.f-title {
  font-size: 30rpx;
  color: #333;
}

.f-sub {
  font-size: 26rpx;
  color: #8A8A8A;
}

.waterfall-wrap {
  height: calc(100vh - 260rpx);
}

/* 根据实际顶部高度调整 */
.waterfall {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  padding-bottom: 40rpx;
}

.col {
  width: 48%;
}

.card {
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, .06);
}

.wall {
  width: 100%;
  display: block;
}

/* loading */
.loading {
  text-align: center;
  padding: 30rpx;
  color: #888;
}