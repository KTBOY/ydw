<view class="page">
  <!-- nav -->
  <view class="nav">
    <text class="title">少女感壁纸</text>
    <image class="search" src="/static/search.png"></image>
  </view>

  <!-- tabs -->
  <scroll-view class="tabs" scroll-x>
    <block wx:for="{{tabs}}" wx:key="index">
      <view class="tab" data-index="{{index}}" bindtap="switchTab">
        <text class="{{currentTab==index?'active':''}}">{{item}}</text>
      </view>
    </block>
  </scroll-view>

  <!-- fortune -->
  <view class="fortune">
    <text class="f-title">今日命定壁纸占卜</text>
    <text class="f-sub">今天适合温柔一点</text>
  </view>

  <!-- 瀑布流，两列 -->
  <!-- <scroll-view class="waterfall-wrap" scroll-y scroll-with-animation bindscrolltolower="onReachBottom">
