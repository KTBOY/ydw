        </block>
      </view>
    </view>

    <view class="loading" wx:if="{{loading}}">加载中...</view>
  </scroll-view> -->

  <scroll-view type="custom">
    <grid-view type="masonry" cross-axis-count="2">
      <view wx:for="{{leftList}}">
        <image src="{{item}}" mode="widthFix"></image>
      </view>
    </grid-view>
  </scroll-view>
</view>