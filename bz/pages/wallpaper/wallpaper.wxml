<view class="waterfall">

  <view class="column">
    <view wx:for="{{leftList}}" wx:key="url" style="height: {{item.height}};">
      <!-- <image class="wall-img" src="{{item.img}}" mode="widthFix" /> -->
      <t-image class="wall-img" src="{{item.img}}" mode="widthFix" />
    </view>
  </view>
  <view class="column">
    <view wx:for="{{rightList}}" wx:key="url">
      <!-- <image class="wall-img" src="{{item.img}}" mode="widthFix" /> -->
      <t-image class="wall-img" src="{{item.img}}" mode="widthFix" />
    </view>
  </view>

</view>
<view class="loading" wx:if="{{loading}}">加载中...</view>


<t-image-viewer usingCustomNavbar deleteBtn="{{deleteBtn}}" closeBtn="{{closeBtn}}" showIndex="{{showIndex}}" visible="{{visible}}" images="{{images}}" bind:change="onChange" bind:delete="onDelete" bind:close="onClose"></t-image-viewer>