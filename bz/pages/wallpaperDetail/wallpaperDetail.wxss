/* bz/pages/wallpaperDetail/wallpaperDetail.wxss */

page {
  height: 100%;
  background-color: #fff;

}

.detail {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
}

.down-btn {
  position: absolute;
  bottom: 20rpx;
  /* background-color: var(--td-brand-color); */
  width: 500rpx;
  height: 80rpx;
  line-height: 80rpx;
  color: var(--td-brand-color);
  border-radius: 20rpx;
  text-align: center;
  border: 2rpx solid var(--td-brand-color);
  font-weight: bold;


}

.video-text {
  color: rgb(153, 153, 153);
}