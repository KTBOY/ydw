/* bz/pages/wallpaperDetail/wallpaperDetail.wxss */

page {
  height: 100%;
  background-color: #fff;
}

.detail {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
}

.down-btn {
  position: absolute;
  bottom: 0;
  background-color: var(--td-brand-color);
  width: 310rpx;
  height: 80rpx;
  line-height: 80rpx;
  color: #fff;
  border-radius: 20rpx;
  text-align: center;

}